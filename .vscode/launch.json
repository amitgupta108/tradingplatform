{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Chrome",
            "request": "launch",
            "type": "chrome",
            "url": "https://localhost:443/static/positions.html?instrument=ML",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Server 443",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/serverlocal/app.js",
            "args": ["443", "arg2"],
            "outputCapture": "std"
        }
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Server 449",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/serverlocal/app.js",
            "args": ["449", "arg2"],
            "outputCapture": "std"
        }
    ]
}